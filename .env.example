# SiliconFlow
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V3

# App
# Examples:
#   Windows: D:\Notes
#   macOS/Linux: ~/Notes
SOURCE_DIR=~/Notes
LLM_TIMEOUT_SEC=10
LLM_MAX_RETRY=1
LLM_CONTENT_LIMIT=4000

# Prefetch（启动时批量预请求 LLM 建议，结果写入 <SOURCE_DIR>/.llm_cache.json）
PREFETCH_ENABLED=1
PREFETCH_CONCURRENCY=4
